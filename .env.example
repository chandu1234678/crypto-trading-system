# ── Binance Spot Testnet ──────────────────────────────────────────────────────
# Get keys from: https://testnet.binance.vision/
API_KEY=your_binance_testnet_api_key
API_SECRET=your_binance_testnet_api_secret
API_BASE_URL=https://testnet.binance.vision

# ── Trading settings ──────────────────────────────────────────────────────────
SYMBOL=BTCUSDT
USE_TEST_ORDER=True
DRY_RUN=True
SPEND_QUOTE=10.0
POLL_INTERVAL=30

# ── Strategy thresholds ───────────────────────────────────────────────────────
RSI_OVERSOLD=30.0
RSI_OVERBOUGHT=70.0
EMA_SPAN=20
RSI_WINDOW=14

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
ENV=development
# ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
# Change this in production — never use the default
ADMIN_TOKEN=change_me_in_production

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/trades.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60
