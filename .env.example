# ════════════════════════════════════════════════════════════════════════════
# CTP·BOT — Environment Variables Template
# Copy this file to .env and fill in your values
# cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════

# ── Binance Spot Testnet ──────────────────────────────────────────────────────
# Get free testnet keys from: https://testnet.binance.vision/
API_KEY=your_binance_testnet_api_key_here
API_SECRET=your_binance_testnet_api_secret_here
API_BASE_URL=https://testnet.binance.vision

# ── Trading defaults ──────────────────────────────────────────────────────────
SYMBOL=BTCUSDT
USE_TEST_ORDER=True        # Always True — uses /order/test endpoint
DRY_RUN=True               # True = simulate orders, False = actually place them
SPEND_QUOTE=10.0           # USDT to spend per auto-trade signal
POLL_INTERVAL=30           # Seconds between poller checks

# ── Strategy thresholds (EMA + RSI) ──────────────────────────────────────────
RSI_OVERSOLD=30.0          # RSI below this → potential BUY
RSI_OVERBOUGHT=70.0        # RSI above this → potential SELL
EMA_SPAN=20                # EMA period
RSI_WINDOW=14              # RSI period

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
ENV=development            # development | production

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change this before deploying — never use "admin123" in production
ADMIN_TOKEN=change_me_to_something_secure

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── CORS — comma-separated allowed origins ────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/trades.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
RATE_LIMIT_PER_MINUTE=60   # API rate limit per IP
